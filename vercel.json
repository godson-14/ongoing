{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "ongoing.html",
      "use": "@vercel/static"
    },
    {
      "src": "schoolwork.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "ongoing.html"
    },
    {
      "src": "/(.*)",
      "dest": "schoolwork.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
